# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_service_role_key

# Finnhub API Key (for stock prices)
FINNHUB_API_KEY=your_finnhub_api_key

# News API Key (Marketaux)
NEWS_API_KEY=your_marketaux_api_key

# Metal Price API Key (for gold/silver prices)
METAL_API_KEY=your_metalpriceapi_key

# CORS - set to your Vercel frontend URL after deployment
FRONTEND_URL=https://your-frontend.vercel.app
